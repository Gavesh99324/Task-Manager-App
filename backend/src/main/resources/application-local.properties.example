# Copy this file to application-local.properties and fill in your values.
# application-local.properties is gitignored — never commit it.
spring.data.mongodb.uri=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/taskmanager?retryWrites=true&w=majority
app.jwt.secret=<replace-with-a-long-random-string-at-least-256-bits>
